      "keys": [
        "form_code",
        "form_name",
        "version",
        "sections"
      ]
    },
    {
      "path": "/api/forms/hospitalizacion_ingreso/schema",
      "kind": "json",
      "status": 200,
      "keys": [
        "form_code",
        "form_name",
        "version",
        "sections"
      ]
    },
    {
      "path": "/api/forms/urgencias_solicitud_qx/schema",
      "kind": "json",
      "status": 200,
      "keys": [
        "form_code",
        "form_name",
        "version",
        "sections"
      ]
    },
    {
      "path": "/api/stats/oncology",
