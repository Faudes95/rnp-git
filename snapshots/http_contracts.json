{
  "routes": [
    {
      "path": "/",
      "kind": "html",
      "status": 200,
      "contains": [
        "Bienvenido a UROMED",
        "INGRESAR"
      ]
    },
    {
      "path": "/consulta",
      "kind": "html",
      "status": 200,
      "contains": [
        "Consulta Externa"
      ]
    },
    {
      "path": "/consulta/metadata",
      "kind": "html",
      "status": 200,
      "contains": [
        "Consulta Externa - Metadata Integrada por Secciones",
        "UROMED Navegación Clínica"
      ]
    },
    {
      "path": "/hospitalizacion/metadata",
      "kind": "html",
      "status": 200,
      "contains": [
        "Hospitalización - Piloto Metadata-Driven",
        "UROMED Navegación Clínica"
      ]
    },
    {
      "path": "/quirofano/urgencias/metadata",
      "kind": "html",
      "status": 200,
      "contains": [
        "Urgencias Quirúrgicas - Piloto Metadata-Driven",
        "UROMED Navegación Clínica"
      ]
    },
    {
      "path": "/reporte",
      "kind": "html",
      "status": 200,
      "contains": [
        "REPORTE ESTADÍSTICO"
      ]
    },
    {
      "path": "/admin/connectivity",
      "kind": "json",
      "status": 200,
      "keys": [
        "status",
        "connectivity_mode",
        "vendor_assets",
        "fallback_assets"
      ]
    },
    {
      "path": "/admin/database/status",
